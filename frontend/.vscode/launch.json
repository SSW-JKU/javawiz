{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Frontend (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Frontend: npm run dev",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "vite:///*": "${webRoot}/*",
        "/src/*": "${webRoot}/src/*",
        "/@fs/*": "*"
      }
    }
  ]
}
