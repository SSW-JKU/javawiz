### intellij-plugin — sub-project specific ignores ###
# Build artefacts (also covered by **/build/ above, but explicit for clarity)
intellij-plugin/build/
intellij-plugin/out/
!intellij-plugin/**/src/main/**/build/
!intellij-plugin/**/src/main/**/out/
!intellij-plugin/**/src/test/**/build/
!intellij-plugin/**/src/test/**/out/

# IntelliJ IDEA project files that must not be shared
intellij-plugin/.idea/modules.xml
intellij-plugin/.idea/jarRepositories.xml
intellij-plugin/.idea/compiler.xml
intellij-plugin/.idea/libraries/

# Machine-local AI tool state
intellij-plugin/.idea/copilot.data.migration.*.xml

# Machine-specific remote development targets
intellij-plugin/.idea/remote-targets.xml

# Build-time injected resources — generated by Gradle tasks, never committed
# (mirroring vsc-extension/out/assets/frontend and vsc-extension/out/assets/backend)
intellij-plugin/src/main/resources/Frontend/
intellij-plugin/src/main/resources/Backend/

# IDE-generated source mirror — IntelliJ copies sources here; never commit
intellij-plugin/bin/
