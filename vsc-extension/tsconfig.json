{
  "compilerOptions": {
    "target": "ES2022",
    /* module/moduleResolution: node16/node16 is the required pairing for CommonJS output consumed by Node.js (VS Code extension host). */
    "module": "node16",
    "moduleResolution": "node16",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "outDir": "out",
    "rootDir": "..",
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": "build/typescript/tsconfig.tsbuildinfo",
    /* Interop */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    /* Type Checking */
    "strict": true,
    /* noImplicitAny is already implied by strict — not repeated here. */
    "noUncheckedSideEffectImports": true, /* Explicit: TS 6 default; lock in to prevent silent regressions on future TS changes. */
    /* Completeness */
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@Shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
