{
  "name": "javawiz",
  "displayName": "JavaWiz",
  "description": "Visualize the execution of your Java programs",
  "version": "2.0.0",
  "publisher": "ssw-jku",
  "engines": {
    "vscode": "^1.87.0"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "categories": [
    "Debuggers",
    "Visualization",
    "Education",
    "Other"
  ],
  "keywords": [
    "Visual Debugger",
    "Trace-based Time-Travel Debugger",
    "Software Education and Visualization",
    "Visual Teaching",
    "Program Comprehension and Understanding"
  ],
  "homepage": "https://ssw.jku.at/Research/Projects/JavaWiz/",
  "bugs": {
    "url": "https://ssw.jku.at/General/Staff/Weninger/",
    "email": "markus.weninger@jku.at"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SSW-JKU/javawiz"
  },
  "icon": "img/wizard-hat.png",
  "galleryBanner": {
    "color": "#163150",
    "theme": "dark"
  },
  "preview": false,
  "pricing": "Free",
  "activationEvents": [
    "onCommand:enableIntelliSense",
    "onCommand:disableIntelliSense",
    "onLanguage:java",
    "onWebviewPanel:javawiz"
  ],
  "main": "./out/vsc-extension/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "javawiz.start",
        "title": "Debug with JavaWiz",
        "category": "JavaWiz"
      },
      {
        "command": "javawiz.enableJavaFeatures",
        "title": "Enable Advanced Java Support",
        "category": "JavaWiz"
      },
      {
        "command": "javawiz.disableJavaFeatures",
        "title": "Disable Advanced Java Support",
        "category": "JavaWiz"
      },
      {
        "command": "javawiz.createIn",
        "title": "Create In.java",
        "category": "JavaWiz"
      },
      {
        "command": "javawiz.createOut",
        "title": "Create Out.java",
        "category": "JavaWiz"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == java",
          "command": "javawiz.start"
        },
        {
          "when": "resourceLangId == java",
          "command": "javawiz.enableJavaFeatures"
        },
        {
          "when": "resourceLangId == java",
          "command": "javawiz.disableJavaFeatures"
        }
      ],
      "editor/title/run": [
        {
          "when": "resourceLangId == java",
          "command": "javawiz.start"
        }
      ],
      "explorer/context": [
        {
          "when": "explorerViewletVisible",
          "command": "javawiz.createIn"
        },
        {
          "when": "explorerViewletVisible",
          "command": "javawiz.createOut"
        }
      ]
    },
    "keybindings": [
      {
        "when": "resourceLangId == java",
        "command": "javawiz.start",
        "key": "ctrl+shift+j"
      }
    ],
    "configuration": {
      "title": "JavaWiz",
      "properties": {
        "javawiz.excludeFromSteppingPatterns": {
          "type": "array",
          "default": [
            "java.*",
            "javax.*",
            "javafx.*",
            "sun.*",
            "com.sun.*",
            "jdk.*",
            "*.In",
            "*.Out",
            "*.Rand",
            "In",
            "Out",
            "Rand"
          ],
          "description": "Glob patterns for classes that JavaWiz will not step into and will not instrument (no condition or array-access tracking). Changing this configuration might break functionality."
        },
        "javawiz.excludeFieldsPatterns": {
          "type": "array",
          "default": [
            "java.*",
            "javax.*",
            "javafx.*",
            "sun.*",
            "com.sun.*",
            "jdk.*",
            "*.In",
            "*.Out",
            "*.Rand",
            "In",
            "Out",
            "Rand"
          ],
          "description": "Glob patterns for classes whose fields JavaWiz will not collect. Classes matching detailedFieldsPatterns take precedence over this setting. Changing this configuration might break functionality."
        },
        "javawiz.detailedFieldsPatterns": {
          "type": "array",
          "default": [
            "java.util.*",
            "java.util.concurrent.*"
          ],
          "description": "Glob patterns for classes whose fields are collected (for specialised visualisations such as the List or Tree view) but are hidden in the Memory View. Takes precedence over excludeFieldsPatterns."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint",
    "watch": "cd .. && gradlew.bat clean && gradlew.bat build -PexcludeTests && cd vsc-extension && tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/http-server": "^0.12.1",
    "@types/lodash": "^4.17.0",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.87.0",
    "@types/websocket": "^1.0.5",
    "@eslint/js": "^9.38.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.38.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "child-process": "^1.0.2",
    "globals": "^16.4.0",
    "http-server": "^14.1.1",
    "lodash": "^4.17.21",
    "tree-kill": "^1.2.2",
    "websocket": "^1.0.34"
  },
  "extensionDependencies": [
    "redhat.java",
    "vscjava.vscode-java-debug"
  ]
}
